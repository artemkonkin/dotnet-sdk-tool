<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:dotnet_sdk_tool_template.ViewModels"
        xmlns:services="using:dotnet_sdk_tool_template.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="dotnet_sdk_tool_template.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960" Height="660" MinWidth="720" MinHeight="520"
        Icon="/Assets/avalonia-logo.ico"
        Title=".NET SDK Installer">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="20,16" Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                    <TextBlock Text=".N" FontSize="18" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text=".NET SDK Installer" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PlatformDescription, StringFormat='Install any supported .NET — {0}'}"
                               FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <TextBlock Text="Show legacy" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ToggleSwitch IsChecked="{Binding ShowLegacy}" OnContent="" OffContent=""/>
                </StackPanel>

                <Button Grid.Column="3" Content="Refresh" Command="{Binding LoadCommand}"
                        IsEnabled="{Binding !IsLoading}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status / log panel -->
        <Border DockPanel.Dock="Bottom" Padding="20,10"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ProgressBar Grid.Column="1" Width="160" IsIndeterminate="True"
                                 IsVisible="{Binding IsInstalling}" VerticalAlignment="Center"/>
                </Grid>

                <Expander Header="Installation log" HorizontalAlignment="Stretch">
                    <Grid RowDefinitions="*,Auto" Height="180">
                        <TextBox Grid.Row="0" Text="{Binding InstallLog, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalContentAlignment="Top"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        <Button Grid.Row="1" Content="Clear log" Command="{Binding ClearLogCommand}"
                                HorizontalAlignment="Right" Margin="0,8,0,0"/>
                    </Grid>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Channel list -->
        <Panel>
            <ScrollViewer Padding="20,16">
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DotnetChannelViewModel">
                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                                        <!-- Version block -->
                                        <StackPanel Grid.Column="0" Width="92" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChannelVersion}" FontSize="26" FontWeight="Bold"/>
                                            <TextBlock Text=".NET" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Classes="typePill" IsVisible="{Binding ReleaseType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <TextBlock Text="{Binding ReleaseType}"/>
                                                </Border>
                                                <Border Classes="pill" Background="{Binding StatusKey, Converter={StaticResource StatusToBrush}}">
                                                    <TextBlock Text="{Binding StatusText}"/>
                                                </Border>
                                                <Border Classes="typePill" IsVisible="{Binding IsSecurity}">
                                                    <TextBlock Text="🛡 Security update"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="13"
                                                       Text="{Binding LatestSdk, StringFormat='Latest SDK: {0}'}"/>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="{Binding EolText}"/>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right" Width="200">
                                            <ComboBox ItemsSource="{Binding AvailableKinds}"
                                                      SelectedItem="{Binding SelectedKind}"
                                                      IsEnabled="{Binding !IsBusyOrInstalled}"
                                                      HorizontalAlignment="Stretch" FontSize="12">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:InstallKindOption">
                                                        <TextBlock Text="{Binding Label}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Install latest -->
                                            <Button Content="Install latest" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Classes="accent"
                                                    IsVisible="{Binding !IsBusyOrInstalled}"
                                                    Command="{Binding InstallLatestCommand}"/>

                                            <!-- Installing -->
                                            <Button Content="Installing… Cancel" HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    IsVisible="{Binding IsInstalling}"
                                                    Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).CancelCommand}"/>

                                            <!-- Installed -->
                                            <TextBlock Text="✓ Installed" HorizontalAlignment="Right"
                                                       FontWeight="SemiBold" Foreground="#16A34A"
                                                       IsVisible="{Binding IsInstalled}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- All versions -->
                                    <Expander Header="All versions" HorizontalAlignment="Stretch"
                                              IsExpanded="{Binding IsExpanded}">
                                        <StackPanel Spacing="6">
                                            <ProgressBar IsIndeterminate="True" Height="4"
                                                         IsVisible="{Binding IsLoadingReleases}"/>
                                            <TextBlock Text="{Binding ReleasesError}" Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding ReleasesError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                            <ItemsControl ItemsSource="{Binding Releases}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:DotnetReleaseViewModel">
                                                        <Border Padding="0,8" BorderThickness="0,0,0,1"
                                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                                                <StackPanel Grid.Column="0" Width="110" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ReleaseVersion}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding ReleaseDate}" FontSize="11"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                </StackPanel>

                                                                <TextBlock Grid.Column="1" Text="{Binding CveText}"
                                                                           VerticalAlignment="Center" FontSize="12"
                                                                           Foreground="#B45309"
                                                                           IsVisible="{Binding IsSecurity}"/>

                                                                <WrapPanel Grid.Column="2" Orientation="Horizontal"
                                                                           HorizontalAlignment="Right">
                                                                    <Button Content="{Binding SdkButtonText}" Margin="4"
                                                                            FontSize="11" IsVisible="{Binding HasSdk}"
                                                                            IsEnabled="{Binding !IsBusyOrInstalled}"
                                                                            Command="{Binding InstallKindCommand}"
                                                                            CommandParameter="{x:Static services:InstallKind.Sdk}"/>
                                                                    <Button Content="{Binding RuntimeButtonText}" Margin="4"
                                                                            FontSize="11" IsVisible="{Binding HasRuntime}"
                                                                            IsEnabled="{Binding !IsBusyOrInstalled}"
                                                                            Command="{Binding InstallKindCommand}"
                                                                            CommandParameter="{x:Static services:InstallKind.Runtime}"/>
                                                                    <Button Content="{Binding AspNetButtonText}" Margin="4"
                                                                            FontSize="11" IsVisible="{Binding HasAspNet}"
                                                                            IsEnabled="{Binding !IsBusyOrInstalled}"
                                                                            Command="{Binding InstallKindCommand}"
                                                                            CommandParameter="{x:Static services:InstallKind.AspNetCoreRuntime}"/>
                                                                    <Button Content="{Binding WindowsDesktopButtonText}" Margin="4"
                                                                            FontSize="11" IsVisible="{Binding HasWindowsDesktop}"
                                                                            IsEnabled="{Binding !IsBusyOrInstalled}"
                                                                            Command="{Binding InstallKindCommand}"
                                                                            CommandParameter="{x:Static services:InstallKind.WindowsDesktopRuntime}"/>
                                                                    <TextBlock Text="✓" Foreground="#16A34A" Margin="4"
                                                                               VerticalAlignment="Center" FontWeight="Bold"
                                                                               IsVisible="{Binding IsInstalled}"/>
                                                                </WrapPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading overlay -->
            <Border IsVisible="{Binding IsLoading}" Background="{DynamicResource SystemRegionBrush}" Opacity="0.7">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressBar IsIndeterminate="True" Width="200"/>
                    <TextBlock Text="Loading .NET releases…" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Panel>
    </DockPanel>
</Window>
