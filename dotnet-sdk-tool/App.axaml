<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="dotnet_sdk_tool_template.App"
             xmlns:local="using:dotnet_sdk_tool_template"
             xmlns:conv="using:dotnet_sdk_tool_template.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>

        <!-- ============ Modern terminal palette (Tokyo Night) ============ -->
        <SolidColorBrush x:Key="Bg"          Color="#1A1B26"/>
        <SolidColorBrush x:Key="PanelAlt"    Color="#16161E"/>
        <SolidColorBrush x:Key="Panel"       Color="#1F2335"/>
        <SolidColorBrush x:Key="RowHover"    Color="#272D43"/>
        <SolidColorBrush x:Key="Hairline"    Color="#222536"/>
        <SolidColorBrush x:Key="HairlineHot" Color="#3B4261"/>
        <SolidColorBrush x:Key="Text"        Color="#C0CAF5"/>
        <SolidColorBrush x:Key="Muted"       Color="#828BB8"/>
        <SolidColorBrush x:Key="Faint"       Color="#565F89"/>
        <SolidColorBrush x:Key="Green"       Color="#9ECE6A"/>
        <SolidColorBrush x:Key="GreenDim"    Color="#243227"/>
        <SolidColorBrush x:Key="Amber"       Color="#E0AF68"/>
        <SolidColorBrush x:Key="Blue"        Color="#7AA2F7"/>
        <SolidColorBrush x:Key="Cyan"        Color="#7DCFFF"/>
        <SolidColorBrush x:Key="Magenta"     Color="#BB9AF7"/>
        <SolidColorBrush x:Key="Red"         Color="#F7768E"/>

        <FontFamily x:Key="MonoFont">Cascadia Code,Cascadia Mono,JetBrains Mono,Fira Code,Consolas,monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Everything is monospace -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        </Style>

        <!-- ===================== Tabs ===================== -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabControl WrapPanel">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="tabRoot" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>
        <Style Selector="TabItem:selected:pointerover">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>

        <!-- ===================== Panels ===================== -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- Row separator (no hover here) -->
        <Style Selector="Border.item">
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Clean hover highlight: instant, rounded, no transition artifacts -->
        <Style Selector="Border.hover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.hover:pointerover">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
        </Style>

        <!-- ===================== Chevron toggle ===================== -->
        <Style Selector="ToggleButton.chevron">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleButton.chevron:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.chevron:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.chevron Path">
            <Setter Property="Fill" Value="{StaticResource Faint}"/>
            <Setter Property="RenderTransform" Value="rotate(0deg)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.chevron:pointerover Path">
            <Setter Property="Fill" Value="{StaticResource Muted}"/>
        </Style>
        <Style Selector="ToggleButton.chevron:checked Path">
            <Setter Property="Fill" Value="{StaticResource Green}"/>
            <Setter Property="RenderTransform" Value="rotate(90deg)"/>
        </Style>

        <!-- ===================== Buttons ===================== -->
        <Style Selector="Button.term">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.term:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>
        <Style Selector="Button.term:disabled /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{StaticResource Faint}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        </Style>

        <Style Selector="Button.termghost">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.termghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HairlineHot}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style Selector="Button.termdanger">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Red}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3A2330"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.termdanger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A2330"/>
            <Setter Property="BorderBrush" Value="{StaticResource Red}"/>
        </Style>

        <Style Selector="Button.kindlet">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
        <Style Selector="Button.kindlet:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>

        <!-- Compact combo -->
        <Style Selector="ComboBox.kind">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
        <Style Selector="ComboBox.kind /template/ Border#Background">
            <Setter Property="Background" Value="{StaticResource PanelAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Application.Styles>
</Application>
