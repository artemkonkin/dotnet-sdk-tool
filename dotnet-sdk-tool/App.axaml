<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="dotnet_sdk_tool_template.App"
             xmlns:local="using:dotnet_sdk_tool_template"
             xmlns:conv="using:dotnet_sdk_tool_template.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>

        <!-- ============ Terminal palette (modern TUI) ============ -->
        <SolidColorBrush x:Key="Bg"        Color="#0A0E14"/>
        <SolidColorBrush x:Key="Panel"     Color="#0E141F"/>
        <SolidColorBrush x:Key="PanelAlt"  Color="#070A10"/>
        <SolidColorBrush x:Key="RowHover"  Color="#121C2A"/>
        <SolidColorBrush x:Key="Hairline"  Color="#1C2837"/>
        <SolidColorBrush x:Key="HairlineHot" Color="#2C3E54"/>
        <SolidColorBrush x:Key="Text"      Color="#C8D3E0"/>
        <SolidColorBrush x:Key="Muted"     Color="#6B7B90"/>
        <SolidColorBrush x:Key="Faint"     Color="#43526A"/>
        <SolidColorBrush x:Key="Green"     Color="#4ADE80"/>
        <SolidColorBrush x:Key="GreenDim"  Color="#1C3A29"/>
        <SolidColorBrush x:Key="Amber"     Color="#FBBF24"/>
        <SolidColorBrush x:Key="Blue"      Color="#60A5FA"/>
        <SolidColorBrush x:Key="Magenta"   Color="#C084FC"/>
        <SolidColorBrush x:Key="Red"       Color="#F87171"/>

        <FontFamily x:Key="MonoFont">Cascadia Code,Cascadia Mono,JetBrains Mono,Fira Code,Consolas,monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- Everything is monospace -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        </Style>

        <!-- ===================== Tabs as terminal commands ===================== -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabControl WrapPanel">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="{StaticResource Green}"/>
        </Style>

        <!-- ===================== Panels (boxed) ===================== -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <!-- ===================== Channel row ===================== -->
        <Style Selector="Border.row">
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.row:pointerover">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
        </Style>

        <!-- ===================== Chevron toggle ===================== -->
        <Style Selector="ToggleButton.chevron">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Faint}"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton.chevron:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
        </Style>
        <Style Selector="ToggleButton.chevron Path">
            <Setter Property="Fill" Value="{StaticResource Muted}"/>
            <Setter Property="RenderTransform" Value="rotate(0deg)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.chevron:checked Path">
            <Setter Property="Fill" Value="{StaticResource Green}"/>
            <Setter Property="RenderTransform" Value="rotate(90deg)"/>
        </Style>

        <!-- ===================== Bracket buttons ===================== -->
        <Style Selector="Button.term">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.term:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>
        <Style Selector="Button.term:disabled /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{StaticResource Faint}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
        </Style>

        <!-- Neutral bracket button -->
        <Style Selector="Button.termghost">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.termghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource RowHover}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HairlineHot}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <!-- Danger bracket button -->
        <Style Selector="Button.termdanger">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Red}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3A1F22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.termdanger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A1416"/>
            <Setter Property="BorderBrush" Value="{StaticResource Red}"/>
        </Style>

        <!-- Tiny release-kind button -->
        <Style Selector="Button.kindlet">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
        <Style Selector="Button.kindlet:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenDim}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
        </Style>

        <!-- Compact combo -->
        <Style Selector="ComboBox.kind">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
        <Style Selector="ComboBox.kind /template/ Border#Background">
            <Setter Property="Background" Value="{StaticResource PanelAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Keycap hint -->
        <Style Selector="Border.key">
            <Setter Property="Background" Value="{StaticResource PanelAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.key > TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>

        <!-- Blinking cursor -->
        <Style Selector="TextBlock.cursor">
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Style.Animations>
                <Animation Duration="0:0:1.1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                    <KeyFrame Cue="49%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>
</Application>
